# Full Docker-test: backend + Postgres.
# API går på 8080 for å unngå konflikt med lokal backend på 5184.

POSTGRES_DB=evolix_dev
POSTGRES_USER=evolix_app
POSTGRES_PASSWORD=change-this-dev-password

JWT_ISSUER=evolix-api-dev
JWT_AUDIENCE=evolix-client-dev
JWT_SECRET_KEY=replace-with-a-long-dev-secret-key
REFRESH_TOKEN_LIFETIME_DAYS=250

API_HOST_PORT=8080
DB_HOST_PORT=5433
