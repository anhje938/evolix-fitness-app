# Production: API i Docker, PostgreSQL direkte på VPS-en.
# Hvis databasen kjører på samme VPS, bruk host.docker.internal i connection stringen.

CONNECTION_STRING=Host=host.docker.internal;Port=5432;Database=evolix_prod;Username=evolix_app;Password=replace-with-a-strong-db-password

JWT_ISSUER=evolix-api
JWT_AUDIENCE=evolix-client
JWT_SECRET_KEY=replace-with-a-long-random-production-secret
REFRESH_TOKEN_LIFETIME_DAYS=250

APPLE_CLIENT_ID=replace-with-your-apple-client-id
CORS_ORIGIN_0=https://evolix.no
CORS_ORIGIN_1=https://www.evolix.no

API_BIND_ADDRESS=127.0.0.1
API_HOST_PORT=8080
